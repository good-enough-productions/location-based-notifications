{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"]
    },
    "typeRoots": [
      "./node_modules/@types",
      "./types",
      "./"
    ],
    "types": [],
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "lib": ["ES2020", "DOM"],
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "expo-modules.d.ts",
    "jest-globals.d.ts",
    "jest.d.ts",
    "node.d.ts",
    "types/react-native.d.ts",
    "jest.setup.js"
  ],
  "exclude": [
    "node_modules"
  ]
}
